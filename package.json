{
  "name": "reflectdev",
  "displayName": "ReflectDev — AI Chat Evaluator",
  "description": "Score your developer competency from your AI chat sessions",
  "version": "0.1.0",
  "publisher": "reflectdev",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Education"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "reflectdev.openDashboard",
        "title": "ReflectDev: Open Dashboard"
      },
      {
        "command": "reflectdev.importChat",
        "title": "ReflectDev: Import Chat"
      },
      {
        "command": "reflectdev.exportReport",
        "title": "ReflectDev: Export Report"
      },
      {
        "command": "reflectdev.clearData",
        "title": "ReflectDev: Clear Data"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "reflectdev",
          "title": "ReflectDev",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "reflectdev": [
        {
          "id": "reflectdev-sidebar",
          "name": "ReflectDev",
          "type": "tree"
        }
      ]
    },
    "configuration": {
      "title": "ReflectDev",
      "properties": {
        "reflectdev.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable ReflectDev."
        },
        "reflectdev.sources.claudeCLI": {
          "type": "boolean",
          "default": true,
          "description": "Enable Claude CLI session extraction."
        },
        "reflectdev.sources.terminalWatch": {
          "type": "boolean",
          "default": false,
          "description": "Enable terminal watching for chat sessions."
        },
        "reflectdev.scoring.mode": {
          "type": "string",
          "enum": [
            "student",
            "developer"
          ],
          "default": "student",
          "description": "Scoring mode: student or developer."
        },
        "reflectdev.ui.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show ReflectDev status bar item."
        }
      }
    }
  },
  "scripts": {
    "compile": "webpack --mode production",
    "watch": "webpack --watch --mode development",
    "test:unit": "jest",
    "package": "vsce package",
    "lint": "eslint src --ext ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "tiktoken": "^1.0.17",
    "compromise": "^14.13.0",
    "natural": "^6.12.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.0",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@types/natural": "^5.1.5",
    "typescript": "^5.4.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "ts-loader": "^9.5.1",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "@vscode/vsce": "^2.24.0",
    "eslint": "^8.57.0"
  }
}
